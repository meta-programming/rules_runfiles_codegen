#!/usr/bin/env bash
#
# Wrapper script for runfilesdevtool.
# Enables running the tool from anywhere in the repository.

set -euo pipefail

# Get the directory of this script (repo/tools/)
TOOLS_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"

# Run the tool from the tools directory, passing all arguments
exec go run -C "$TOOLS_DIR" ./cmd/runfilesdevtool "$@"
